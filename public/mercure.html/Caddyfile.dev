# Learn how to configure the Mercure.rocks Hub on https://mercure.rocks/docs/hub/config
{
	{$GLOBAL_OPTIONS}
}

{$SERVER_NAME:http://127.0.0.1:2019}

log {
	format filter {
		wrap console
		fields {
			uri query {
				replace authorization REDACTED
			}
		}
	}
}

{$EXTRA_DIRECTIVES}

route {
	encode zstd gzip

	mercure {
		# Transport to use (default to Bolt)
		transport bolt {
			path C:/wamp64/www/depannage_auto/public/mercure.html/mercure.db
		}
		# Publisher JWT key
		publisher_jwt {$MERCURE_JWT_SECRET:depannage_auto_mercure_secret_key_2026_secure}
		# Permissive configuration for the development environment
		cors_origins *
		publish_origins *
		demo
		anonymous
		subscriptions
		# Extra directives
		{$MERCURE_EXTRA_DIRECTIVES}
	}

	redir / /.well-known/mercure/ui/
	respond /healthz 200
	respond "Not Found" 404
}
