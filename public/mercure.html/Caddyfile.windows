{
	auto_https off
	admin off
}

http://127.0.0.1:2019 {
	log

	route {
		mercure {
			publisher_jwt depannage_auto_mercure_secret_key_2026_secure
			subscriber_jwt depannage_auto_mercure_secret_key_2026_secure
			cors_origins http://127.0.0.1 http://localhost http://localhost:8000
			publish_origins *
			anonymous
			subscriptions
			demo
		}

		respond /healthz 200
		redir / /.well-known/mercure/ui/
	}
}
